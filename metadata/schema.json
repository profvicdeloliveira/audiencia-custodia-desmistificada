{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Audiência de Custódia desmistificada",
  "description": "Schema FAIR para o artigo 'Audiência de Custódia desmistificada: influxos e contrafluxos na Investigação Policial à luz dos Direitos Humanos', incluindo metadados acadêmicos essenciais.",
  "type": "object",

  "required": [
    "title",
    "author",
    "doi",
    "datePublished",
    "@type",
    "version",
    "jsonld_path"
  ],

  "properties": {
    "title": {
      "type": "string",
      "const": "Audiência de Custódia desmistificada: influxos e contrafluxos na Investigação Policial à luz dos Direitos Humanos"
    },

    "author": {
      "type": "string",
      "const": "Vicente de Paulo Silva e Oliveira"
    },

    "orcid": {
      "type": "string",
      "const": "0009-0006-4436-0915"
    },

    "doi": {
      "type": "string",
      "const": "10.5281/zenodo.19603643"
    },

    "datePublished": {
      "type": "string",
      "const": "2025-10"
    },

    "@type": {
      "type": "string",
      "const": "ScholarlyArticle"
    },

    "version": {
      "type": "string",
      "const": "1.0"
    },

    "jsonld_path": {
      "type": "string",
      "const": "metadata/article.jsonld"
    },

    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "default": [
        "audiência de custódia",
        "investigação policial",
        "direitos humanos",
        "juízo das garantias",
        "controle constitucional",
        "processo penal",
        "delegado de polícia"
      ]
    },

    "docs_path": {
      "type": "string",
      "const": "docs/"
    },

    "metadata_path": {
      "type": "string",
      "const": "metadata/"
    },

    "src_path": {
      "type": "string",
      "const": "src/texto.md"
    }
  }
}
